# ── Primary AI Provider (Groq — free, fastest) ─────────────────────────────
# Vision: Llama 4 Maverick (best) → Llama 4 Scout → Llama 3.2 11B (auto-fallback)
# Text:   llama-3.3-70b-versatile
# Get free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Fallback AI Provider (Google Gemini — free tier) ────────────────────────
# Model: gemini-2.0-flash (vision + text)
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional Providers ───────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
AICC_API_KEY=your_aicc_api_key_here

# ── Optional: OpenWeatherMap (leave blank to use open-meteo for free) ────────
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

PORT=5000
